{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/pre-tool-use.js"
          }
        ]
      },
      {
        "matcher": "TodoWrite|TaskCreate|TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/todowrite-sync.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/post-tool-use.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/pre-compact.js"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|local_settings",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/config-guard.js"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/teammate-idle.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/task-completed.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node <HOOKS_DIR>/stop.js"
          }
        ]
      }
    ]
  }
}
